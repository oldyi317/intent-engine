# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environment
venv/
env/
.venv/

# Environment variables (IMPORTANT: never commit API keys)
.env
.env.local

# BERT model files (too large for git, download at runtime via HF Hub)
models/bert_intent/
models/*.bin
models/*.pt
models/*.safetensors
*.onnx

# NOTE: svm_best.pkl, tfidf_vectorizer.pkl are KEPT in git (< 100MB)
# They are required for the SVM layer to work on Render.

# Data files (training data, databases)
data/
*.csv
*.tsv
*.jsonl
*.db
*.sqlite
*.pickle

# Keep specific JSON files needed by the app
# (eval_report.json, bert_eval_report.json, bert_history.json, etc.)
# So we do NOT use a blanket *.json rule here.

# IDE
.vscode/
.idea/
*.swp
*.swo
.history/

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Logs
*.log
logs/

# Test / cache
.pytest_cache/
htmlcov/
.coverage
